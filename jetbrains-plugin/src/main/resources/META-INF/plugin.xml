<idea-plugin>
    <id>dev.periscope.phpstorm</id>
    <name>php-periscope</name>
    <vendor email="thamibn@live.co.za" url="https://periscope.thamibn.com">periscopephp</vendor>

    <description><![CDATA[
        <p>Live observability + time-travel debugger for Laravel. Pauses any request, shows every
        variable, SQL query, log line, dispatched job, fired event, cache hit, Redis command, and
        outbound HTTP call that occurred up to the paused line — and lets you scrub backward in time.</p>
        <p>Connects to <code>periscope-daemon</code> over DAP-stdio. Supports breakpoints,
        step over / into / out, <strong>step back</strong>, variables, watches, evaluate.</p>
    ]]></description>

    <change-notes><![CDATA[
        <h3>0.1.0</h3>
        <ul>
            <li>Initial scaffold — registers the <code>periscope</code> debug type and Run/Debug configuration.</li>
        </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.xdebugger</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.jetbrains.php</depends>

    <extensions defaultExtensionNs="com.intellij">
        <configurationType
            implementation="dev.periscope.phpstorm.runconfig.PeriscopeRunConfigurationType"/>
        <programRunner
            implementation="dev.periscope.phpstorm.runconfig.PeriscopeDebuggerRunner"/>
        <notificationGroup id="Periscope" displayType="BALLOON"/>
        <postStartupActivity
            implementation="dev.periscope.phpstorm.runconfig.PeriscopeAutoConfigActivity"/>
        <applicationService
            serviceImplementation="dev.periscope.phpstorm.settings.PeriscopeApplicationSettings"/>
        <applicationConfigurable
            parentId="tools"
            id="dev.periscope.phpstorm.settings.PeriscopeConfigurable"
            displayName="Periscope"
            instance="dev.periscope.phpstorm.settings.PeriscopeConfigurable"/>
    </extensions>

    <actions>
        <!--
          Step Back slots in immediately after the standard Step Out button on
          PhpStorm's existing debug toolbar — sits in the natural step-*
          cluster instead of getting tacked on at the end. The action is
          enabled+visible ONLY while a periscope debug session is the active
          one; during a regular Xdebug session the button is hidden, so the
          toolbar matches PhpStorm's stock layout for Xdebug users.
        -->
        <action id="periscope.StepBack"
                class="dev.periscope.phpstorm.action.StepBackAction"
                text="Step Back"
                description="Move the trace cursor one step backward (periscope time-travel)"
                icon="AllIcons.Actions.Back">
            <add-to-group group-id="XDebugger.ToolWindow.TopToolbar"
                          anchor="after" relative-to-action="StepOut"/>
            <keyboard-shortcut keymap="$default" first-keystroke="control alt shift F7"/>
        </action>

        <!--
          Continue Backward is NOT added to the toolbar — it lives only as a
          keyboard shortcut + Run-menu item to keep the toolbar uncluttered.
          The user is one Ctrl+Alt+F9 away when they want it; toolbar real
          estate is reserved for actions used per-step.
        -->
        <action id="periscope.ReverseContinue"
                class="dev.periscope.phpstorm.action.ReverseContinueAction"
                text="Continue Backward"
                description="Continue replay in reverse until the previous breakpoint (periscope time-travel)"
                icon="AllIcons.Actions.Rewind">
            <add-to-group group-id="RunMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="control alt F9"/>
        </action>
    </actions>
</idea-plugin>
