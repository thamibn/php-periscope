root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{c,h,m4}]
indent_size = 4

[*.{rs}]
indent_size = 4

[*.{ts,tsx,js,jsx,json,yml,yaml,md}]
indent_size = 2

[*.{php,phpt}]
indent_size = 4

[Makefile]
indent_style = tab
